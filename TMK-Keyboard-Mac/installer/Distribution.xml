<?xml version="1.0" encoding="utf-8"?>
<installer-gui-script minSpecVersion="1">
  <title>TMK Keyboard</title>
  <welcome file="welcome.html" mime-type="text/html"/>
  <conclusion file="conclusion.html" mime-type="text/html"/>
  <background file="tmk-keyboard-installer.png" mime-type="image/png" alignment="center" scaling="proportional"/>
  <options customize="never" rootVolumeOnly="true"/>
  <domains enable_anywhere="false" enable_currentUserHome="false" enable_localSystem="true"/>
  <choices-outline>
    <line choice="tmk-keyboard"/>
  </choices-outline>
  <choice id="tmk-keyboard" title="TMK Keyboard" description="Install the TMK Keyboard Shan Unicode keyboard layout.">
    <pkg-ref id="org.tmk.keyboardlayout.tmk-keyboard.pkg"/>
  </choice>
  <pkg-ref id="org.tmk.keyboardlayout.tmk-keyboard.pkg" version="1.0" auth="Root">tmk-keyboard-layout.pkg</pkg-ref>
</installer-gui-script>
